# Hygraph Content API (High Performance / CDN endpoint recommended)
# Project → Settings → API Access
#
# HYGRAPH_ENDPOINT: server-only, read at runtime on Vercel (set to the same URL
# as below). Prevents 404s when NEXT_PUBLIC_* was not available at build time.
HYGRAPH_ENDPOINT=https://eu-central-1-shared-euc1-02.cdn.hygraph.com/content/cmn7eamxe01eb08w7iw79c0qe/master

NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://eu-central-1-shared-euc1-02.cdn.hygraph.com/content/cmn7eamxe01eb08w7iw79c0qe/master

# Hygraph Studio base URL (no trailing slash)
NEXT_PUBLIC_HYGRAPH_STUDIO_URL=https://studio-eu-central-1-shared-euc1-02.hygraph.com

# Permanent Auth Tokens (Project Settings → Access → Permanent Auth Tokens)
# PREVIEW_TOKEN: default content stage = DRAFT (draft + preview)
PREVIEW_TOKEN=

# PRODUCTION_TOKEN: default content stage = PUBLISHED (live site)
PRODUCTION_TOKEN=

# Secret for /api/draft — any long random string; must match Hygraph Preview URL query param
HYGRAPH_PREVIEW_SECRET=

# Canonical site URL for metadata and Open Graph (your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://unit4-hygraph-site.vercel.app
